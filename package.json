{
  "name": "nodejs-postgres-app",
  "version": "1.0.0",
  "description": "NodeJS application with PostgreSQL and environment-specific configurations",
  "main": "src/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=dev nodemon src/server.js",
    "release": "cross-env NODE_ENV=release node src/server.js",
    "prod": "cross-env NODE_ENV=prod node src/server.js",
    "start": "node src/server.js",
    "test": "cross-env NODE_ENV=test node --test",
    "test:unit": "cross-env NODE_ENV=test node --test src/**/*.test.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\""
  },
  "keywords": [
    "nodejs",
    "postgresql",
    "express",
    "rest-api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1"
  }
}
